exports.update = async (id, data) => {
  await db.query(`
    UPDATE services
    SET
      name=$1,
      type=$2,
      base_price=$3,
      duration_minutes=$4,
      is_active=$5
    WHERE id=$6
  `, [
    data.name,
    data.type,
    data.base_price,
    data.duration_minutes,
    data.is_active,
    id
  ])
}

exports.toggle = async (id) => {
  await db.query(`
    UPDATE services
    SET is_active = NOT is_active
    WHERE id = $1
  `, [id])
}
