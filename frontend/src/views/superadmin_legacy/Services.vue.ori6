  padding: 24px;
}

/* HEADER */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.subtitle {
  color: var(--text-muted);
  font-size: 13px;
}

/* FILTER */
.filters {
  display: flex;
  gap: 12px;
  align-items: center;
  padding: 14px;
  margin: 18px 0;
  background: #111;
  border-radius: 14px;
}
