<template>
  <div class="page">
    <!-- HEADER -->
    <div class="header">
      <div>
        <h2>Services</h2>
        <p class="subtitle">
          Manage SPA / LC / FNB / Karaoke services
        </p>
      </div>

      <button class="btn-primary" @click="openAdd">
        + Add Service
      </button>
    </div>

    <!-- FILTER -->
    <div class="filters">
      <input
        v-model="keyword"
        class="input"
        placeholder="Search service name..."
      />

      <select v-model="selectedBranch" class="select">
        <option value="">All Branches</option>
        <option
          v-for="b in branches"
          :key="b.id"
          :value="b.id"
        >
          {{ b.name }}
        </option>
      </select>

      <select v-model="selectedType" class="select">
        <option value="">All Types</option>
        <option value="SPA">SPA</option>
        <option value="LC">LC</option>
        <option value="FNB">FNB</option>
        <option value="KARAOKE">KARAOKE</option>
      </select>

      <button class="btn-search" @click="loadServices">
        Search
      </button>
    </div>

    <!-- TABLE -->
    <div class="card table-card">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Duration</th>
            <th>Price</th>
            <th>Status</th>
            <th width="220">Actions</th>
          </tr>
        </thead>

        <tbody>
          <tr v-if="loading">
            <td colspan="6" class="empty">Loading...</td>
          </tr>

          <tr v-else-if="!services.length">
            <td colspan="6" class="empty">No services found</td>
          </tr>

          <tr
            v-for="s in services"
            :key="s.id"
            class="row-hover"
          >
            <td class="name">{{ s.name }}</td>

            <td>
              <span class="badge type">{{ s.type }}</span>
            </td>

            <td>
              {{ s.duration_minutes ? s.duration_minutes + " min" : "-" }}
            </td>

            <td class="price">
              Rp {{ format(s.base_price) }}
            </td>

            <td>
              <span
                class="badge"
                :class="s.is_active ? 'success' : 'danger'"
              >
                {{ s.is_active ? "ACTIVE" : "DISABLED" }}
              </span>
            </td>

            <td class="actions">
              <button class="btn-outline" @click="edit(s)">
                Edit
              </button>
              <button
                :class="s.is_active ? 'btn-danger' : 'btn-success'"
                @click="toggle(s)"
              >
                {{ s.is_active ? "Disable" : "Enable" }}
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- MODAL -->
    <ServiceForm
      v-if="showForm"
      :edit="!!selected"
      :data="selected"
      @saved="reload"
      @close="close"
    />
  </div>
</template>

<script setup>
import { ref, onMounted } from "vue"
import api from "@/services/api"
import ServiceForm from "./ServiceForm.vue"

/* =========================
   STATE
========================= */
const services = ref([])
const branches = ref([])

const selectedBranch = ref("")
const selectedType = ref("")
const keyword = ref("")

const loading = ref(false)

const showForm = ref(false)
const selected = ref(null)

/* =========================
   LOAD BRANCHES
========================= */
const loadBranches = async () => {
  const res = await api.get("/branches")
  branches.value = res.data.data || res.data
}

/* =========================
   LOAD SERVICES (SINGLE SOURCE OF TRUTH)
========================= */
const loadServices = async () => {
  loading.value = true
  try {
    const res = await api.get("/services", {
      params: {
        branch_id: selectedBranch.value || undefined,
        type: selectedType.value || undefined,
        q: keyword.value || undefined
      }
    })
    services.value = res.data.data || res.data
  } finally {
    loading.value = false
  }
}

/* =========================
   INIT
========================= */
onMounted(async () => {
  await loadBranches()
  await loadServices()
})

/* =========================
   ACTIONS
========================= */
const openAdd = () => {
  selected.value = null
  showForm.value = true
}

const edit = (s) => {
  selected.value = { ...s }
  showForm.value = true
}

const toggle = async (s) => {
  await api.put(`/services/${s.id}/toggle`)
  s.is_active = !s.is_active
}

const reload = async () => {
  showForm.value = false
  selected.value = null
  await loadServices()
}

const close = () => {
  showForm.value = false
  selected.value = null
}

/* =========================
   UTIL
========================= */
const format = (v) =>
  Number(v || 0).toLocaleString("id-ID")
</script>

