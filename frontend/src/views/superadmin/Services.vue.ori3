  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.subtitle {
  font-size: 13px;
  color: var(--text-muted);
}

.filter-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 12px;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  padding: 12px;
  border-bottom: 1px solid var(--border-soft);
}

.badge {
  background: rgba(201,162,77,.15);
  color: var(--gold);
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
}

.status.on {
  background: #0f3;
  color: #000;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 12px;
}

.status.off {
  background: #a22;
  color: #fff;
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 12px;
}

.actions {
  display: flex;
  gap: 8px;
}

.btn-primary {
  background: var(--gold);
  color: black;
  padding: 8px 14px;
}

.btn-outline {
  border: 1px solid var(--gold);
  color: var(--gold);
  padding: 6px 12px;
}

.btn-danger {
  background: #7a1e1e;
  color: white;
  padding: 6px 12px;
}

.btn-success {
  background: #1e7a3a;
  color: white;
  padding: 6px 12px;
}

button:hover {
  transform: translateY(-1px);
}

.empty {
  text-align: center;
  padding: 20px;
  color: var(--text-muted);
}
</style>
